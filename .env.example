# Public Firebase web app config
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=north-allen-perfume.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=north-allen-perfume
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=north-allen-perfume.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=734936382792
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_web_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Server-only Firebase Admin credentials
# Put real values only in .env.local or Vercel env vars. Do not commit them.
FIREBASE_PROJECT_ID=north-allen-perfume
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="paste_escaped_private_key_here"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Email
RESEND_API_KEY=your_resend_api_key
RESEND_WEBHOOK_SECRET=your_resend_inbound_webhook_secret
EMAIL_FROM="North Allen Perfumery <orders@yourdomain.com>"
ADMIN_EMAIL=you@example.com
PERSONAL_ORDER_EMAIL=you@example.com

# Twilio voice receptionist and transactional order calls
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+14699403197
# Set this to your deployed origin if Twilio signature validation fails behind a proxy.
TWILIO_PUBLIC_BASE_URL=https://www.northallenperfumery.org

# Optional comma-separated 100% off promo codes managed outside Firestore
PROMO_CODES=

# App URL
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3001
